    "ring_inactive": "#444444",
    "text_primary": "#FFFFFF",
    "text_secondary": "#A0A0A0",
    "text_dark": "#1A1A1A",
    "energy_icon": "#00E5FF",
    "coin_icon": "#FFD700",
    "heart_icon": "#FF3B30",
    "pill_border": "rgba(255, 255, 255, 0.1)"
  },
  "typography": {
    "font_family_primary": "System",
    "font_family_pixel_fallback": "Courier New",
    "h1": {
      "size": "24px",
      "weight": "bold",
      "color": "#FFFFFF"
    },
    "h2": {
      "size": "18px",
      "weight": "bold",
      "color": "#FFFFFF"
    },
    "body": {
      "size": "14px",
      "weight": "normal",
      "color": "#FFFFFF"
    },
    "tiny_stats": {
      "size": "10px",
      "weight": "bold",
      "color": "#FFFFFF"
    }
  },
  "spacing": {
    "xs": "4px",
    "sm": "8px",
