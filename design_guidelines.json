    "room_area": {
      "flex": 1,
      "background": "#E8D4A6",
      "border_top_left_radius": "24px",
      "border_top_right_radius": "24px",
      "position": "relative"
    },
    "tab_pills_row": {
      "position": "absolute",
      "bottom": "90px",
      "left": "0px",
      "right": "0px",
      "justify_content": "center",
      "gap": "12px",
      "pill_height": "36px",
      "pill_padding_horizontal": "16px"
    },
    "chat_bottom_bar": {
      "position": "absolute",
      "bottom": "24px",
      "left": "16px",
      "right": "16px",
      "height": "48px",
      "background": "#2A2A2A",
      "border_radius": "9999px",
      "padding_horizontal": "12px"
    }
  },
