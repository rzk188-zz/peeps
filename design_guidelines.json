  "shadows": {
    "pill_glow": "0px 4px 12px rgba(0, 0, 0, 0.3)",
    "item_shadow": "0px 2px 4px rgba(0, 0, 0, 0.15)"
  },
  "layout_specs": {
    "avatar_ring_row": {
      "height": "80px",
      "padding_horizontal": "16px",
      "gap": "12px",
      "active_border_width": "3px",
      "inactive_border_width": "2px",
      "avatar_size": "56px"
    },
    "stats_bar": {
      "height": "40px",
      "padding_horizontal": "16px",
      "pill_height": "28px",
      "pill_padding_horizontal": "12px",
      "gap": "8px"
