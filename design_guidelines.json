{
  "theme": {
    "mode": "dark",
    "archetype": "Pixel-Art Dark Mode (Custom Retro)",
    "description": "8-bit retro aesthetic mixed with a modern dark theme. Pill-shaped UI elements, pixel-art graphics, and a warm tan room floor contrasting with a deep dark background."
  },
  "colors": {
    "background_main": "#0F0F12",
    "surface_pill": "#2A2A2A",
    "surface_room": "#E8D4A6",
